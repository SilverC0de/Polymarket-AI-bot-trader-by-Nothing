PORT=8088
LIVE_TRADING=false


# ── Polymarket CLOB API credentials (generated by scripts/gen-api-keys.mjs) ──
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=

# ── Live trading credentials ──────────────────────────────────────────────────
# Export your EOA private key from: https://reveal.magic.link/polymarket
POLYMARKET_PRIVATE_KEY=
# Your proxy wallet address from polymarket.com/profile (where your pUSD sits)
POLYMARKET_PROXY_WALLET=
# Signature type: 1=POLY_PROXY (Telegram/email/Google), 2=GNOSIS_SAFE (browser wallet)
POLYMARKET_SIG_TYPE=1

# ── Feature flag ──────────────────────────────────────────────────────────────
# Set to "true" to place real orders. Any other value = simulation only.

REDIS_URL=